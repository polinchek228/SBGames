{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SBGames-Launcher",
  "version": "1.0.6",
  "identifier": "com.sbgames.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SB Games Launcher",
        "width": 1100,
        "height": 680,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true,
        "maximized": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "shadow": true,
        "visible": true
      },
      {
        "label": "tray",
        "title": "SB Games Tray",
        "width": 360,
        "height": 520,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": false,
        "shadow": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://games.sb-capital.group wss://games.sb-capital.group https://*.hyperionsearch.xyz https://minotar.net https://api.modrinth.com https://sessionserver.mojang.com https://api.mojang.com https://api.allorigins.win https://rsshub.app https://fonts.googleapis.com https://fonts.gstatic.com; img-src 'self' data: https: blob:; media-src 'self' https://games.sb-capital.group https://*.hyperionsearch.xyz; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; frame-src 'none'; object-src 'none'; base-uri 'self'; navigate-to 'self' http://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyQTQ0REE0N0JFODI2MzMKUldRekp1aDdwRTJrc3BoTnlJUGpObXBnenBLWjJaaFptMU1zVTc1bWtuemZwbTZJSy9VZWlIU1UK",
      "endpoints": [
        "https://games.sb-capital.group/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
