{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SBGames Launcher",
  "version": "1.0.0",
  "identifier": "com.sbgames.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "SB Games Launcher",
        "width": 1100,
        "height": 680,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "shadow": true,
        "visible": true
      },
      {
        "label": "tray",
        "title": "SB Games Tray",
        "width": 360,
        "height": 520,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": false,
        "shadow": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      },
      {
        "label": "mcbar",
        "title": "SBGames Titlebar",
        "width": 854,
        "height": 36,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": false,
        "shadow": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://api.sbgames.hyperionsearch.xyz:8443 wss://api.sbgames.hyperionsearch.xyz:8443 https://minotar.net https://api.modrinth.com https://sessionserver.mojang.com https://api.mojang.com https://api.allorigins.win https://rsshub.app https://fonts.googleapis.com https://fonts.gstatic.com; img-src 'self' data: https: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
